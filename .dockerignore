# Docker ignore file for MidiShuffle project

# Dependency directories
node_modules/

# Build output
build/
dist/

# Environment files
.env
.env.local
.env.development
.env.test
.env.production

# IDE and editor files
.idea/
.vscode/
*.swp
*.swo

# Git files
.git/
.gitignore

# Logs and debug files
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Test coverage
coverage/
.lcov

# Docker files
!docker/
!docker/**/*
!Dockerfile
!docker-compose.yml
!docker-compose.*.yml